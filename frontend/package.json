{
  "name": "mindflow-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:verified": "next build && npm run check:bundle",
    "start": "next start",
    "lint": "next lint",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "test:e2e:visual": "playwright test tests/e2e/visual.spec.ts --workers=1",
    "test:e2e:contracts": "playwright test tests/e2e/contracts.spec.ts"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@tanstack/react-query": "^5.100.9",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.2",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@types/node": "20.16.10",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "typescript": "5.6.3"
  }
}
