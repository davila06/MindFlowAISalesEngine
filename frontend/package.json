{
  "name": "mindflow-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:verified": "next build && npm run check:bundle",
    "start": "next start",
    "lint": "next lint",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:a11y": "npm run build && playwright test tests/e2e/accessibility.spec.ts",
    "test:e2e:visual": "npm run build && playwright test tests/e2e/visual.spec.ts --workers=1",
    "test:e2e:contracts": "npm run build && playwright test tests/e2e/contracts.spec.ts",
    "test:unit": "jest --config jest.config.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.8.2",
    "@playwright/test": "^1.60.0",
    "@tanstack/react-query": "^5.100.9",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.2",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.19",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "eslint": "10.4.0",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-storybook": "^10.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "playwright": "^1.60.0",
    "ts-jest": "^29.4.9",
    "typescript": "5.6.3"
  }
}
