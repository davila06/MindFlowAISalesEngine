{
  "Security": {
    "AllowedCorsOrigins": [
      "https://staging.novamind.app",
      "https://staging-api.novamind.app"
    ],
    "JwtIssuer": "novamind-staging",
    "JwtAudience": "novamind-staging-clients"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/data/mindflow-staging.db"
  },
  "DataGovernance": {
    "RetentionDays": 365,
    "EnableAnonymization": true
  },
  "Features": {
    "DisableDataRetentionBackground": false,
    "EnableCanaryFeatures": true,
    "EnableBetaRulesEngine": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AnalyticsAdvancedCache": {
    "TtlSeconds": 120
  },
  "WeeklyAnalyticsReports": {
    "CronSchedule": "0 8 * * 1"
  },
  "Observability": {
    "Environment": "staging",
    "RetentionDays": 30
  }
}
